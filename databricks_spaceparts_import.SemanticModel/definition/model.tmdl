model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Customer","Order Type","Order Status","Product","orders_fact_databricks","Date","_Measure"]

annotation PBI_ProTooling = ["WebModelingEdit","TMDL-Extension","DevMode"]

annotation __TEdtr = 1

ref table Customer
ref table 'Order Type'
ref table 'Order Status'
ref table Product
ref table orders_fact_databricks
ref table Date
ref table _Measure

ref cultureInfo en-US

